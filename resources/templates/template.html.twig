    <!-- Deferred Facebook Pixel - loads after page is ready -->
    <script>
    window.addEventListener('load', function() {
        // Load Facebook Pixel only after user interaction or 5 seconds
        var fbLoaded = false;
        function loadFBPixel() {
            if (fbLoaded) return;
            fbLoaded = true;
            !function(f,b,e,v,n,t,s)
            {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
                n.callMethod.apply(n,arguments):n.queue.push(arguments)};
                if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
                n.queue=[];t=b.createElement(e);t.async=!0;
                t.src=v;s=b.getElementsByTagName(e)[0];
                s.parentNode.insertBefore(t,s)}(window, document,'script',
                'https://connect.facebook.net/en_US/fbevents.js');
            fbq('init', '4371677243055821');
            fbq('track', 'PageView');
        }
        // Load on first interaction or after 5 seconds
        ['scroll', 'click', 'touchstart', 'mousemove'].forEach(function(e) {
            document.addEventListener(e, loadFBPixel, {once: true, passive: true});
        });
        setTimeout(loadFBPixel, 5000);
    });
    </script>
