{% extends "template.html.twig" %}

{% block title %}Service Areas | Clean Gutters Crew - Metro Vancouver{% endblock %}

{% block meta %}
<meta name="description" content="Clean Gutters Crew serves all Metro Vancouver communities: Vancouver, Burnaby, Surrey, Richmond, Coquitlam, Langley, Delta, North Vancouver, West Vancouver and more." />
<meta name="robots" content="index,follow" />
<link rel="canonical" href="https://cgc-services.ca/areas" />
{% endblock %}

{% block content %}
<main>
    <section class="areas-page-section">
        <div class="container">
            <h1 class="areas-page-title">Metro Vancouver Communities We Serve</h1>
            <p class="areas-page-subtitle">
                Clean Gutters Crew provides gutter cleaning, window washing, pressure washing, moss removal, junk removal and handyman services across all Metro Vancouver communities.
            </p>
            
            <div class="areas-grid">
                <a href="/cities/vancouver" class="area-card">Vancouver</a>
                <a href="/cities/burnaby" class="area-card">Burnaby</a>
                <a href="/cities/surrey" class="area-card">Surrey</a>
                <a href="/cities/richmond" class="area-card">Richmond</a>
                <a href="/cities/coquitlam" class="area-card">Coquitlam</a>
                <a href="/cities/langley" class="area-card">Langley</a>
                <a href="/cities/delta" class="area-card">Delta</a>
                <a href="/cities/new_westminster" class="area-card">New Westminster</a>
                <a href="/cities/north_vancouver" class="area-card">North Vancouver</a>
                <a href="/cities/west_vancouver" class="area-card">West Vancouver</a>
                <a href="/cities/maple_ridge" class="area-card">Maple Ridge</a>
                <a href="/cities/pitt_meadows" class="area-card">Pitt Meadows</a>
                <a href="/cities/port_coquitlam" class="area-card">Port Coquitlam</a>
                <a href="/cities/port_moody" class="area-card">Port Moody</a>
                <a href="/cities/white_rock" class="area-card">White Rock</a>
                <a href="/cities/tsawwassen" class="area-card">Tsawwassen</a>
                <a href="/cities/ladner" class="area-card">Ladner</a>
            </div>
            
            <div class="areas-cta">
                <a class="btn-primary" href="/quote">Get Free Quote (1 min)</a>
            </div>
        </div>
    </section>
</main>
{% endblock %}
