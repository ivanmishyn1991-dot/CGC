<header>
    <div class="container header-inner">
        <!-- Desktop-only left header button -->
        <a
                href="https://mail.google.com/mail/?view=cm&fs=1&to=cgc.services.bc@gmail.com"
                class="btn-email"
                id="headerEmailBtn"
                aria-label="Email cgc.services.bc@gmail.com"
        >
            <span class="btn-main">cgc.services.bc@gmail.com</span>
        </a>

        <div class="logo" id="logoHome" title="Home">
            <a href="/"><img src="/assets/images/logo.webp" alt="Clean Gutters Crew logo" width="189" height="80" style="aspect-ratio: 189/80; display: block;" fetchpriority="high"></a>
        </div>

        <nav id="main-nav" aria-label="Primary">
            <a href="/#about">About</a>
            <a href="/#quote" data-page-link="quote">Quote</a>
            <a href="/#services">Services</a>
            <a href="/#faq">FAQ</a>
            <a href="#" id="headerAreasTrigger" data-action="openCitiesModal">Areas</a>
        </nav>

        <!-- Desktop right header button becomes copy-phone -->
        <a href="tel:+16725006060" class="btn-call" id="headerPhoneBtn" aria-label="Phone +1 (672) 500-6060">
            <span class="btn-main">+1 (672) 500-6060</span>
        </a>

        <!-- Desktop-only "✓ Copied" badge -->
        <div class="copied-badge" id="copiedBadge" aria-live="polite" aria-atomic="true">
            <span class="tick">✓</span>
            <span>Copied</span>
        </div>

        <button class="hamburger" aria-label="Menu" aria-controls="main-nav" aria-expanded="false" type="button">☰</button>
    </div>
</header>